{"cells": [{"cell_type": "code", "execution_count": null, "metadata": {}, "outputs": [], "source": ["import os\nimport numpy as np\nimport tensorflow as tf\nfrom tensorflow import keras\nfrom tensorflow.keras import layers\n\n# Set the path to the dataset\nBASE_DIR = 'C:/Users/HP/Downloads/archive (1)/AutismDataset/consolidated'\n\n# Check if the dataset exists\nif not os.path.exists(BASE_DIR):\n    raise FileNotFoundError(f'Dataset not found at {BASE_DIR}')\n\n# Load dataset and split into training and validation sets\ntry:\n    dataset = keras.preprocessing.image_dataset_from_directory(\n        BASE_DIR,\n        image_size=(224, 224),\n        batch_size=32,\n        validation_split=0.2,\n        seed=123,\n        shuffle=True\n    )\nexcept Exception as e:\n    raise RuntimeError(f'Error loading dataset: {str(e)}')\n\n# Define the CNN model\ndef create_model():\n    model = keras.Sequential([\n        layers.Conv2D(32, (3, 3), activation='relu', input_shape=(224, 224, 3)),\n        layers.MaxPooling2D(),\n        layers.Conv2D(64, (3, 3), activation='relu'),\n        layers.MaxPooling2D(),\n        layers.Conv2D(128, (3, 3), activation='relu'),\n        layers.MaxPooling2D(),\n        layers.Flatten(),\n        layers.Dense(128, activation='relu'),\n        layers.Dense(2, activation='softmax')\n    ])\n    return model\n\n# Compile the model\nmodel = create_model()\nmodel.compile(\n    optimizer='adam',\n    loss='sparse_categorical_crossentropy',\n    metrics=['accuracy']\n)\n\n# Fit the model\ntry:\n    history = model.fit(dataset, epochs=10)\nexcept Exception as e:\n    raise RuntimeError(f'Error during training: {str(e)}')\n\n# Save the model\nmodel.save('autism_cnn_model.h5')\nprint('Model saved successfully!')\n"}], "metadata": {"kernelspec": {"display_name": "Python 3", "language": "python", "name": "python3"}, "name": "Autism CNN Training"}, "nbformat": 4, "nbformat_minor": 4}