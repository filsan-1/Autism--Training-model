# =========================================================
# Autism Image Classification with CNN — Improved Pipeline
# =========================================================
# Improvements over baseline:
#   - Class weights to handle imbalance (autistic vs non-autistic)
#   - Aggressive data augmentation (rotation, shift, zoom, brightness, flip)
#   - Deeper CNN architecture with BatchNormalization (4 conv blocks)
#   - Recall + Precision tracked as training metrics
#   - ModelCheckpoint saves the best epoch by validation recall
#   - EarlyStopping and ReduceLROnPlateau monitor validation recall
#   - Decision-threshold tuning to maximise recall for the autistic class
#   - Full evaluation: confusion matrix, ROC curve, Precision-Recall curve
#
# Folder structure required:
#
# <DATASET_DIR>
# ├── autistic
# │   ├── image1.jpg
# │   └── ...
# └── non_autistic
#     ├── image1.jpg
#     └── ...
#
# Install first if needed:
#   pip install tensorflow matplotlib scikit-learn
# =========================================================

import os
import numpy as np
import matplotlib.pyplot as plt
import tensorflow as tf
from sklearn.metrics import (
    classification_report,
    confusion_matrix,
    roc_curve,
    auc,
    precision_recall_curve,
)
from sklearn.utils.class_weight import compute_class_weight
from tensorflow.keras import regularizers
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import (
    BatchNormalization,
    Conv2D,
    Dense,
    Dropout,
    Flatten,
    Input,
    MaxPooling2D,
)
from tensorflow.keras.callbacks import EarlyStopping, ModelCheckpoint, ReduceLROnPlateau
from tensorflow.keras.preprocessing.image import ImageDataGenerator, img_to_array, load_img
from tensorflow.keras.optimizers import Adam

# ----------------------------
# SETTINGS
# ----------------------------
DATASET_DIR = r"C:\Users\HP\Downloads\archive (1)\AutismDataset\consolidated"
IMG_HEIGHT = 128
IMG_WIDTH = 128
BATCH_SIZE = 16
EPOCHS = 30
SEED = 42
MODEL_SAVE_PATH = "autism_detection_model.keras"
BEST_MODEL_PATH = "autism_detection_model_best.keras"

# ----------------------------
# CHECK DATASET PATH
# ----------------------------
if not os.path.exists(DATASET_DIR):
    raise FileNotFoundError(
        f"Dataset folder not found:\n{DATASET_DIR}\n\n"
        "Please update DATASET_DIR above to point to your dataset."
    )

class_folders = [
    folder for folder in os.listdir(DATASET_DIR)
    if os.path.isdir(os.path.join(DATASET_DIR, folder))
]

if len(class_folders) < 2:
    raise ValueError(
        f"Your dataset folder must contain at least 2 class folders.\n"
        f"Found: {class_folders}\n"
        "Example: autistic and non_autistic"
    )

print("Dataset found.")
print("Class folders:", class_folders)

# ----------------------------
# LOAD ALL IMAGES INTO MEMORY
# (required for class-weight calculation and threshold tuning)
# ----------------------------
CLASS_MAP = {}
images_list, labels_list = [], []

for label_idx, class_name in enumerate(sorted(class_folders)):
    folder_path = os.path.join(DATASET_DIR, class_name)
    filenames = [f for f in os.listdir(folder_path) if not f.startswith(".")]
    CLASS_MAP[class_name] = label_idx
    for fname in filenames:
        img_path = os.path.join(folder_path, fname)
        try:
            img = load_img(img_path, target_size=(IMG_HEIGHT, IMG_WIDTH))
            images_list.append(img_to_array(img) / 255.0)
            labels_list.append(label_idx)
        except Exception:
            pass
    print(f"  Loaded {len(filenames)} images from '{class_name}' (label={label_idx})")

images_arr = np.array(images_list, dtype="float32")
labels_arr = np.array(labels_list, dtype="int32")
print(f"\nTotal images: {len(images_arr)}")
print("Class mapping:", CLASS_MAP)

# Identify which label corresponds to the autistic class
AUTISTIC_LABEL = CLASS_MAP.get("autistic", CLASS_MAP.get("Autistic", 1))

# ----------------------------
# TRAIN / VALIDATION SPLIT
# ----------------------------
from sklearn.model_selection import train_test_split

X_train, X_val, y_train, y_val = train_test_split(
    images_arr, labels_arr, test_size=0.2, random_state=SEED, stratify=labels_arr
)
print(f"Train: {len(X_train)}  |  Validation: {len(X_val)}")

# ----------------------------
# CLASS WEIGHTS
# (upweight the autistic class so the model does not ignore it)
# ----------------------------
unique_classes = np.unique(y_train)
weights = compute_class_weight("balanced", classes=unique_classes, y=y_train)
class_weights = dict(zip(unique_classes.tolist(), weights.tolist()))
print("Class weights:", class_weights)

# ----------------------------
# DATA AUGMENTATION
# ----------------------------
train_datagen = ImageDataGenerator(
    rotation_range=30,
    width_shift_range=0.2,
    height_shift_range=0.2,
    zoom_range=0.25,
    horizontal_flip=True,
    brightness_range=[0.8, 1.2],
    channel_shift_range=20.0,
    fill_mode="nearest",
)

# ----------------------------
# BUILD MODEL
# (deeper: 4 conv blocks 32->64->128->256, BatchNorm, moderate dropout)
# ----------------------------
l2 = regularizers.l2(1e-4)

model = Sequential([
    Input(shape=(IMG_HEIGHT, IMG_WIDTH, 3)),

    # Block 1
    Conv2D(32, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    Conv2D(32, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    MaxPooling2D(pool_size=(2, 2)),
    Dropout(0.25),

    # Block 2
    Conv2D(64, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    Conv2D(64, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    MaxPooling2D(pool_size=(2, 2)),
    Dropout(0.25),

    # Block 3
    Conv2D(128, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    Conv2D(128, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    MaxPooling2D(pool_size=(2, 2)),
    Dropout(0.3),

    # Block 4
    Conv2D(256, (3, 3), activation="relu", padding="same", kernel_regularizer=l2),
    BatchNormalization(),
    MaxPooling2D(pool_size=(2, 2)),
    Dropout(0.3),

    Flatten(),
    Dense(512, activation="relu", kernel_regularizer=l2),
    Dropout(0.5),
    Dense(1, activation="sigmoid"),
])

# ----------------------------
# COMPILE MODEL
# (track recall and precision so callbacks can monitor them)
# ----------------------------
model.compile(
    optimizer=Adam(learning_rate=0.0005),
    loss="binary_crossentropy",
    metrics=[
        "accuracy",
        tf.keras.metrics.Recall(name="recall"),
        tf.keras.metrics.Precision(name="precision"),
    ],
)

model.summary()

# ----------------------------
# CALLBACKS
# ----------------------------
callbacks = [
    # Save the epoch with the highest validation recall
    ModelCheckpoint(
        filepath=BEST_MODEL_PATH,
        monitor="val_recall",
        mode="max",
        save_best_only=True,
        verbose=1,
    ),
    # Stop early if validation recall stops improving
    EarlyStopping(
        monitor="val_recall",
        mode="max",
        patience=7,
        restore_best_weights=True,
        verbose=1,
    ),
    # Reduce learning rate when validation recall plateaus
    ReduceLROnPlateau(
        monitor="val_recall",
        mode="max",
        factor=0.5,
        patience=4,
        min_lr=1e-6,
        verbose=1,
    ),
]

# ----------------------------
# TRAIN MODEL
# ----------------------------
history = model.fit(
    train_datagen.flow(X_train, y_train, batch_size=BATCH_SIZE),
    epochs=EPOCHS,
    validation_data=(X_val, y_val),
    class_weight=class_weights,
    callbacks=callbacks,
)

# ----------------------------
# THRESHOLD TUNING
# Sweep thresholds; prefer recall >= 0.65 then pick best F1
# ----------------------------
y_pred_prob = model.predict(X_val, verbose=0).flatten()

best_thresh = 0.5
best_f1 = 0.0
thresh_records = []
print("\n--- Threshold sweep ---")
print(f"{'Threshold':>10}  {'Recall':>8}  {'Precision':>10}  {'F1':>8}")
for t in np.arange(0.25, 0.66, 0.05):
    y_pred_t = (y_pred_prob >= t).astype(int)
    tn_t, fp_t, fn_t, tp_t = confusion_matrix(y_val, y_pred_t).ravel()
    rec = tp_t / (tp_t + fn_t) if (tp_t + fn_t) > 0 else 0.0
    prec = tp_t / (tp_t + fp_t) if (tp_t + fp_t) > 0 else 0.0
    f1 = 2 * prec * rec / (prec + rec) if (prec + rec) > 0 else 0.0
    thresh_records.append({"threshold": round(float(t), 2), "recall": rec, "f1": f1})
    print(f"{t:>10.2f}  {rec:>8.4f}  {prec:>10.4f}  {f1:>8.4f}")
    if rec >= 0.65 and f1 > best_f1:
        best_f1 = f1
        best_thresh = float(t)

if best_f1 == 0.0:
    # No threshold met recall >= 0.65; fall back to the one with the highest recall
    best_thresh = max(thresh_records, key=lambda r: r["recall"])["threshold"]

print(f"\nSelected threshold: {best_thresh:.2f}")

y_pred = (y_pred_prob >= best_thresh).astype(int)

# ----------------------------
# EVALUATE MODEL
# ----------------------------
tn, fp, fn, tp = confusion_matrix(y_val, y_pred).ravel()
recall    = tp / (tp + fn) if (tp + fn) > 0 else 0.0
precision = tp / (tp + fp) if (tp + fp) > 0 else 0.0
f1_score  = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0.0
specificity = tn / (tn + fp) if (tn + fp) > 0 else 0.0
accuracy  = (tp + tn) / (tp + tn + fp + fn)

print(f"\n--- Validation results (threshold={best_thresh:.2f}) ---")
print(f"Accuracy:    {accuracy:.4f}")
print(f"Recall:      {recall:.4f}  (autistic class)")
print(f"Precision:   {precision:.4f}")
print(f"F1-Score:    {f1_score:.4f}")
print(f"Specificity: {specificity:.4f}")
print(f"TP={tp}  TN={tn}  FP={fp}  FN={fn}")
print()
print(classification_report(y_val, y_pred, target_names=["Non_Autistic", "Autistic"]))

# ----------------------------
# CONFUSION MATRIX PLOT
# ----------------------------
cm = confusion_matrix(y_val, y_pred)
fig, ax = plt.subplots(figsize=(6, 5))
im = ax.imshow(cm, interpolation="nearest", cmap=plt.cm.Blues)
plt.colorbar(im, ax=ax)
classes = ["Non_Autistic", "Autistic"]
tick_marks = np.arange(len(classes))
ax.set_xticks(tick_marks); ax.set_xticklabels(classes, rotation=45, ha="right")
ax.set_yticks(tick_marks); ax.set_yticklabels(classes)
thresh = cm.max() / 2.0
for i in range(cm.shape[0]):
    for j in range(cm.shape[1]):
        ax.text(j, i, format(cm[i, j], "d"), ha="center", va="center",
                color="white" if cm[i, j] > thresh else "black")
ax.set_ylabel("True label"); ax.set_xlabel("Predicted label")
ax.set_title(f"Confusion Matrix (threshold={best_thresh:.2f})")
plt.tight_layout()
plt.savefig("confusion_matrix.png", dpi=150)
plt.show()

# ----------------------------
# TRAINING CURVES
# ----------------------------
fig, axes = plt.subplots(1, 3, figsize=(15, 4))
axes[0].plot(history.history["accuracy"], label="Train")
axes[0].plot(history.history["val_accuracy"], label="Val")
axes[0].set_title("Accuracy"); axes[0].set_xlabel("Epoch")
axes[0].legend(); axes[0].grid(True)

axes[1].plot(history.history["loss"], label="Train")
axes[1].plot(history.history["val_loss"], label="Val")
axes[1].set_title("Loss"); axes[1].set_xlabel("Epoch")
axes[1].legend(); axes[1].grid(True)

axes[2].plot(history.history["recall"], label="Train")
axes[2].plot(history.history["val_recall"], label="Val")
axes[2].set_title("Recall (Autistic class)"); axes[2].set_xlabel("Epoch")
axes[2].legend(); axes[2].grid(True)

plt.tight_layout()
plt.savefig("training_history.png", dpi=150)
plt.show()

# ----------------------------
# ROC CURVE
# ----------------------------
fpr, tpr, _ = roc_curve(y_val, y_pred_prob)
roc_auc = auc(fpr, tpr)
plt.figure(figsize=(6, 5))
plt.plot(fpr, tpr, lw=2, label=f"ROC curve (AUC = {roc_auc:.4f})")
plt.plot([0, 1], [0, 1], "k--", lw=1)
plt.xlabel("False Positive Rate"); plt.ylabel("True Positive Rate")
plt.title("ROC Curve"); plt.legend(loc="lower right"); plt.grid(True)
plt.tight_layout()
plt.savefig("roc_curve.png", dpi=150)
plt.show()
print(f"ROC-AUC: {roc_auc:.4f}")

# ----------------------------
# PRECISION-RECALL CURVE
# ----------------------------
prec_vals, rec_vals, _ = precision_recall_curve(y_val, y_pred_prob)
pr_auc = auc(rec_vals, prec_vals)
plt.figure(figsize=(6, 5))
plt.plot(rec_vals, prec_vals, lw=2, label=f"PR curve (AUC = {pr_auc:.4f})")
plt.xlabel("Recall"); plt.ylabel("Precision")
plt.title("Precision-Recall Curve (Autistic class)"); plt.legend(loc="upper right"); plt.grid(True)
plt.tight_layout()
plt.savefig("precision_recall_curve.png", dpi=150)
plt.show()
print(f"PR-AUC: {pr_auc:.4f}")

# ----------------------------
# SAVE MODEL
# ----------------------------
model.save(MODEL_SAVE_PATH)
print(f"\nFinal model saved as: {MODEL_SAVE_PATH}")
print(f"Best checkpoint (by val_recall) saved as: {BEST_MODEL_PATH}")
