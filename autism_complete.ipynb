# Updated Code to Load Images Safely

import os
import cv2
import numpy as np

# Define the paths
path_autistic = r'C:\Users\HP\Downloads\archive (1)\AutismDataset\consolidated\Autistic'
path_non_autistic = r'C:\Users\HP\Downloads\archive (1)\AutismDataset\consolidated\Non_Autistic'

# Error handling function

def load_images_from_directory(directory):
    images = []
    for filename in os.listdir(directory):
        file_path = os.path.join(directory, filename)
        try:
            # Load image
            img = cv2.imread(file_path)
            if img is not None:
                images.append(img)
            else:
                print(f'Warning: The file {file_path} is not a valid image.')
        except Exception as e:
            print(f'Error loading image {file_path}: {e}')
    return images

# Load images
autistic_images = load_images_from_directory(path_autistic)
non_autistic_images = load_images_from_directory(path_non_autistic)

